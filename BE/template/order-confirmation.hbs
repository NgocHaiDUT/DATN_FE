<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;border:1px solid #eee;border-radius:8px">
  <h2 style="color:#2D3748;border-bottom:2px solid #E2E8F0;padding-bottom:10px">🛒 Xác nhận đơn hàng #{{orderId}}</h2>
  <p>Xin chào <strong>{{customerName}}</strong>,</p>
  <p>Cảm ơn bạn đã đặt hàng tại <strong>{{shopName}}</strong>! Đơn hàng của bạn đã được ghi nhận.</p>

  <table style="width:100%;border-collapse:collapse;margin:16px 0">
    <thead>
      <tr style="background:#F7FAFC">
        <th style="padding:8px;text-align:left;border-bottom:1px solid #E2E8F0">Sản phẩm</th>
        <th style="padding:8px;text-align:center;border-bottom:1px solid #E2E8F0">SL</th>
        <th style="padding:8px;text-align:right;border-bottom:1px solid #E2E8F0">Thành tiền</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="padding:8px;border-bottom:1px solid #EDF2F7">{{this.name}}{{#if this.variant}} ({{this.variant}}){{/if}}</td>
        <td style="padding:8px;text-align:center;border-bottom:1px solid #EDF2F7">{{this.quantity}}</td>
        <td style="padding:8px;text-align:right;border-bottom:1px solid #EDF2F7">{{this.lineTotal}}đ</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div style="background:#F7FAFC;padding:12px;border-radius:6px;margin:8px 0">
    <p style="margin:4px 0">Tạm tính: <strong>{{subtotal}}đ</strong></p>
    {{#if discount}}<p style="margin:4px 0;color:#38A169">Giảm giá: <strong>-{{discount}}đ</strong></p>{{/if}}
    <p style="margin:4px 0">Phí vận chuyển: <strong>{{shippingFee}}đ</strong></p>
    <p style="margin:8px 0;font-size:18px;color:#2D3748">Tổng cộng: <strong>{{totalAmount}}đ</strong></p>
  </div>

  <div style="margin:12px 0">
    <p style="margin:4px 0">📍 <strong>Giao đến:</strong> {{shippingAddress}}</p>
    <p style="margin:4px 0">💳 <strong>Thanh toán:</strong> {{paymentMethod}}</p>
  </div>

  <p style="margin-top:20px;color:#718096;font-size:13px">Nếu bạn có bất kỳ câu hỏi nào, vui lòng liên hệ với chúng tôi.</p>
</div>
