<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;border:1px solid #eee;border-radius:8px">
  <h2 style="color:#2D3748;border-bottom:2px solid #E2E8F0;padding-bottom:10px">📦 Cập nhật đơn hàng #{{orderId}}</h2>
  <p>Xin chào <strong>{{customerName}}</strong>,</p>
  <p>Đơn hàng của bạn tại <strong>{{shopName}}</strong> đã được cập nhật trạng thái:</p>

  <div style="background:#F7FAFC;padding:16px;border-radius:6px;margin:16px 0;text-align:center">
    <p style="margin:0;font-size:14px;color:#718096">Trạng thái mới</p>
    <p style="margin:8px 0 0;font-size:22px;font-weight:bold;color:#2B6CB0">{{status}}</p>
  </div>

  {{#if trackingNumber}}
  <div style="margin:12px 0;padding:12px;background:#EBF8FF;border-radius:6px">
    <p style="margin:0">🚚 <strong>Mã vận đơn:</strong> {{trackingNumber}}</p>
  </div>
  {{/if}}

  <p style="margin-top:20px;color:#718096;font-size:13px">Nếu bạn có bất kỳ câu hỏi nào, vui lòng liên hệ với chúng tôi.</p>
</div>
