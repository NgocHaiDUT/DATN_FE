Project beauty_ecommerce {
  database_type: "PostgreSQL"
  Note: "DBML for dbdiagram.io, based on BE/prisma/schema.prisma. Some logical references are added for report readability."
}

Enum user_role {
  user
  seller
  admin
  staff
}

Enum auth_provider {
  email
  google
  facebook
}

Enum order_status {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

Enum payment_status {
  unpaid
  paid
  failed
  refunded
  pending
}

Enum shipment_status {
  pending
  packing
  in_transit
  delivered
  failed
  returned
}

Enum return_request_status {
  pending
  approved
  rejected
  completed
}

Enum product_moderation_status {
  pending
  approved
  rejected
  removed
}

Enum moderation_status {
  approved
  rejected
  removed
}

Enum skin_type {
  unknown
  normal
  oily
  dry
  combination
  sensitive
}

Enum message_type {
  TEXT
  IMAGE
  VIDEO
  SHARE_PRODUCT
}

// USERS & AUTH

Table users {
  id int [pk, increment]
  email varchar [unique, not null]
  device_register varchar
  password_hash varchar
  full_name varchar
  avatar_url varchar
  bio varchar
  phone varchar
  role_id int
  firstlogin boolean [default: true]
  is_active boolean [not null, default: true]
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
  updated_at datetime [not null]
}

Table auth_identities {
  id int [pk, increment]
  user_id int [not null]
  provider auth_provider [not null]
  provider_user_id varchar [not null]
  created_at datetime [not null]
  updated_at datetime [not null]

  indexes {
    (provider, provider_user_id) [unique]
  }
}

Table device_otps {
  id int [pk, increment]
  user_id int [not null]
  device_id varchar [not null]
  otp_hash varchar [not null]
  expires_at datetime [not null]
  created_at datetime [not null]
  verified_at datetime

  indexes {
    (user_id, device_id)
    expires_at
  }
}

Table refresh_tokens {
  id int [pk, increment]
  user_id int [not null]
  device_id varchar [not null]
  device_name varchar [not null]
  token varchar [unique, not null]
  expires_at datetime [not null]
  created_at datetime [not null]
  updated_at datetime [not null]
  is_revoked boolean [not null, default: false]

  indexes {
    (user_id, device_id) [unique]
  }
}

Table oauth_login_codes {
  code varchar [pk]
  user_id int [not null]
  device_id varchar
  expires_at datetime [not null]
  used boolean [not null, default: false]

  indexes {
    user_id
    code
    expires_at
  }
}

Table addresses {
  id int [pk, increment]
  user_id int [not null]
  label varchar
  recipient varchar [not null]
  phone varchar [not null]
  province varchar [not null]
  district varchar [not null]
  ward varchar [not null]
  street varchar [not null]
  is_default boolean [not null, default: false]
  created_at datetime [not null]
  ghn_province_id int
  ghn_district_id int
  ghn_ward_code varchar
}

Table role {
  id int [pk, increment]
  name varchar [unique, not null]
}

Table permission {
  id int [pk, increment]
  name varchar [unique, not null]
}

Table rolepermission {
  role_id int [not null]
  permission_id int [not null]

  indexes {
    (role_id, permission_id) [pk]
  }
}

Table userpermission {
  user_id int [not null]
  permission_id int [not null]

  indexes {
    (user_id, permission_id) [pk]
  }
}

// SELLER / SHOP

Table shops {
  id int [pk, increment]
  owner_id int [unique, not null]
  name varchar [not null]
  slug varchar [unique, not null]
  logo_url varchar
  phone varchar
  email varchar
  cover_url varchar
  description varchar
  is_verified boolean [not null, default: false]
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
  updated_at datetime [not null]
  ghn_shop_id int [unique]
  commission_rate decimal [not null, default: 0.03]
}

Table shop_addresses {
  id int [pk, increment]
  shop_id int [not null]
  name varchar [not null]
  phone varchar [not null]
  email varchar
  province varchar [not null]
  district varchar [not null]
  ward varchar [not null]
  street varchar [not null]
  is_default boolean [not null, default: false]
  created_at datetime [not null]
  ghn_province_id int
  ghn_district_id int
  ghn_ward_code varchar
}

Table shop_staffs {
  id int [pk, increment]
  shop_id int [not null]
  user_id int [not null]
  is_manager boolean [not null, default: false]
  created_at datetime [not null]

  indexes {
    (shop_id, user_id) [unique]
  }
}

// CATALOG

Table brands {
  id int [pk, increment]
  name varchar [unique, not null]
  slug varchar [unique, not null]
  logo_url varchar
  created_at datetime [not null]
}

Table categories {
  id int [pk, increment]
  parent_id int
  name varchar [not null]
  slug varchar [unique, not null]
  created_at datetime [not null]
}

Table products {
  id int [pk, increment]
  shop_id int [not null]
  brand_id int
  name varchar [not null]
  slug varchar [unique, not null]
  description varchar
  how_to_use varchar
  moderation_status product_moderation_status [not null, default: "pending"]
  is_published boolean [not null, default: false]
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  avg_rating decimal [default: 0.0]
  review_count int [not null, default: 0]
  view_count int [not null, default: 0]
  created_at datetime [not null]
  updated_at datetime [not null]
}

Table product_categories {
  product_id int [not null]
  category_id int [not null]

  indexes {
    (product_id, category_id) [pk]
  }
}

Table product_media {
  id int [pk, increment]
  product_id int [not null]
  url varchar [not null]
  type varchar
  sort_order int [not null, default: 0]
  created_at datetime [not null]
}

Table product_variants {
  id int [pk, increment]
  product_id int [not null]
  sku varchar [unique, not null]
  name varchar
  shade_hex varchar
  opacity float
  size_label varchar
  price decimal [not null]
  compare_at_price decimal
  stock int [not null, default: 0]
  is_active boolean [not null, default: true]
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
  updated_at datetime [not null]
  weight int
  length int
  width int
  height int
}

// CART / ORDER / PAYMENT / SHIPMENT

Table carts {
  id int [pk, increment]
  user_id int [unique, not null]
  created_at datetime [not null]
  updated_at datetime [not null]
}

Table cart_items {
  id int [pk, increment]
  cart_id int [not null]
  product_id int [not null]
  variant_id int
  quantity int [not null, default: 1]
  price_snapshot decimal [not null]
  created_at datetime [not null]

  indexes {
    (cart_id, product_id, variant_id) [unique]
  }
}

Table orders {
  id int [pk, increment]
  user_id int [not null]
  shop_id int [not null]
  status order_status [not null, default: "pending"]
  payment_status payment_status [not null, default: "unpaid"]
  subtotal_amount decimal [not null, default: 0]
  discount_amount decimal [not null, default: 0]
  shipping_fee decimal [not null, default: 0]
  total_amount decimal [not null, default: 0]
  shipping_address_id int
  pickup_address_id int
  note varchar
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
  updated_at datetime [not null]
  ghn_order_code varchar [unique]
  ghn_expected_delivery_time datetime
  ghn_required_note varchar
  shipping_payer varchar
}

Table order_items {
  id int [pk, increment]
  order_id int [not null]
  product_id int [not null]
  variant_id int
  name_snapshot varchar
  variant_snapshot varchar
  unit_price decimal [not null]
  quantity int [not null]
  line_total decimal [not null]
}

Table payments {
  id int [pk, increment]
  order_id int [not null]
  provider varchar
  amount decimal [not null]
  status payment_status [not null, default: "pending"]
  transaction_id varchar
  payload_raw varchar
  created_at datetime [not null]
}

Table shipments {
  id int [pk, increment]
  order_id int [not null]
  status shipment_status [not null, default: "pending"]
  carrier varchar
  tracking_number varchar
  shipped_at datetime
  delivered_at datetime
  address_snapshot varchar
  created_at datetime [not null]
}

Table shipment_logs {
  id int [pk, increment]
  shipment_id int [not null]
  status varchar [not null]
  location_description varchar
  updated_at datetime [not null]

  indexes {
    (shipment_id, status, updated_at) [unique]
  }
}

// REVIEWS / WISHLIST

Table reviews {
  id int [pk, increment]
  user_id int [not null]
  product_id int [not null]
  rating int [not null]
  title varchar
  content varchar
  media_url varchar
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
  is_verified_purchase boolean [not null, default: false]

  indexes {
    (user_id, product_id) [unique]
  }
}

Table wishlists {
  user_id int [not null]
  product_id int [not null]
  created_at datetime [not null]

  indexes {
    (user_id, product_id) [pk]
  }
}

// AI: SKIN ANALYSIS / AR TRY-ON / RECS

Table skin_analyses {
  id int [pk, increment]
  user_id int
  image_url varchar [not null]
  skin_type_pred skin_type [not null, default: "unknown"]
  issues_json varchar
  routine_advice varchar
  model_version varchar
  created_at datetime [not null]
}

Table tryon_sessions {
  id int [pk, increment]
  user_id int
  device varchar
  input_type varchar
  input_image_url varchar
  result_url varchar
  latency_ms int
  created_at datetime [not null]
}

Table tryon_items {
  id int [pk, increment]
  session_id int [not null]
  product_id int
  variant_id int
  type varchar
  params_json varchar
}

Table recommendations {
  id int [pk, increment]
  user_id int
  source varchar
  context_id int
  items_json varchar
  created_at datetime [not null]
}

// PROMO / COUPON

Table coupons {
  id int [pk, increment]
  code varchar [unique, not null]
  description varchar
  discount_type varchar
  discount_value decimal [not null]
  voucher_type varchar [not null, default: "order"]
  min_subtotal decimal [default: 0]
  usage_limit int
  used_count int [default: 0]
  starts_at datetime
  ends_at datetime
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  created_at datetime [not null]
}

Table order_coupons {
  order_id int [not null]
  coupon_id int [not null]
  user_voucher_id int
  amount decimal [not null]

  indexes {
    (order_id, coupon_id) [pk]
    user_voucher_id
  }
}

Table user_vouchers {
  id int [pk, increment]
  user_id int [not null]
  coupon_id int [not null]
  source varchar
  status varchar [not null, default: "available"]
  starts_at datetime
  expires_at datetime
  used_at datetime
  order_id int
  created_at datetime [not null]

  indexes {
    (user_id, status)
    coupon_id
    expires_at
  }
}

Table vr_model_reviews {
  id int [pk, increment]
  user_id int [not null]
  rating int [not null]
  content varchar
  reward_voucher_id int
  created_at datetime [not null]

  indexes {
    (user_id, created_at)
  }
}

Table vr_review_prompt_settings {
  user_id int [pk]
  snooze_until datetime
  updated_at datetime [not null]
}

// USER WALLET

Table user_wallets {
  id int [pk, increment]
  user_id int [unique, not null]
  balance decimal [not null, default: 0]
  updated_at datetime [not null]
}

Table user_wallet_transactions {
  id int [pk, increment]
  wallet_id int [not null]
  order_id int
  type varchar [not null]
  amount decimal [not null]
  note varchar
  created_at datetime [not null]

  indexes {
    wallet_id
    created_at
  }
}

Table wallet_topup_requests {
  id int [pk, increment]
  wallet_id int [not null]
  amount decimal [not null]
  status varchar [not null, default: "pending"]
  transaction_id varchar
  vnp_txn_ref varchar [unique, not null]
  created_at datetime [not null]
  updated_at datetime [not null]

  indexes {
    wallet_id
    status
  }
}

// SELLER WALLET / COMMISSION / PAYOUT

Table seller_wallets {
  id int [pk, increment]
  shop_id int [unique, not null]
  balance decimal [not null, default: 0]
  pending_balance decimal [not null, default: 0]
  total_earned decimal [not null, default: 0]
  updated_at datetime [not null]
}

Table wallet_transactions {
  id int [pk, increment]
  wallet_id int [not null]
  order_id int
  type varchar [not null]
  amount decimal [not null]
  note varchar
  created_at datetime [not null]

  indexes {
    wallet_id
    created_at
  }
}

Table platform_revenue {
  id int [pk, increment]
  order_id int [unique, not null]
  shop_id int [not null]
  gross_amount decimal [not null]
  commission_rate decimal [not null]
  commission_amt decimal [not null]
  seller_amt decimal [not null]
  settled_at datetime [not null]

  indexes {
    shop_id
    settled_at
  }
}

Table payout_requests {
  id int [pk, increment]
  shop_id int [not null]
  wallet_id int [not null]
  amount decimal [not null]
  bank_name varchar
  bank_account varchar
  account_name varchar
  bank_account_id int
  status varchar [not null, default: "pending"]
  admin_note varchar
  created_at datetime [not null]
  updated_at datetime [not null]

  indexes {
    shop_id
    status
  }
}

Table shop_bank_accounts {
  id int [pk, increment]
  shop_id int [not null]
  bank_name varchar [not null]
  bank_account varchar [not null]
  account_name varchar [not null]
  is_default boolean [not null, default: false]
  created_at datetime [not null]

  indexes {
    shop_id
  }
}

// ADMIN / MODERATION / ANALYTICS

Table moderation_logs {
  id int [pk, increment]
  moderator_id int [not null]
  target_type varchar [not null]
  target_id int [not null]
  action varchar
  reason varchar
  created_at datetime [not null]
}

Table notifications {
  id int [pk, increment]
  user_id int [not null]
  type varchar
  title varchar
  body varchar
  is_read boolean [not null, default: false]
  meta_json varchar
  created_at datetime [not null]
}

Table audit_logs {
  id int [pk, increment]
  actor_id int
  action varchar
  entity_type varchar
  entity_id int
  details varchar
  ip varchar
  created_at datetime [not null]
}

Table conversations {
  id int [pk, increment]
  type varchar [not null, default: "private"]
  created_at datetime [not null]
}

Table conversation_participants {
  id int [pk, increment]
  conversation_id int [not null]
  user_id int
  shop_id int
  entity_type varchar
  role varchar
  joined_at datetime [not null]

  indexes {
    (conversation_id, user_id) [unique]
    (conversation_id, shop_id) [unique]
    user_id
    shop_id
  }
}

Table messages {
  id int [pk, increment]
  conversation_id int [not null]
  sender_id int
  sender_shop_id int
  sender_type varchar
  type message_type [not null, default: "TEXT"]
  content varchar
  is_edited boolean [not null, default: false]
  edited_at datetime
  is_deleted boolean [not null, default: false]
  deleted_at datetime
  reply_to_id int
  created_at datetime [not null]
  payload json

  indexes {
    sender_id
    sender_shop_id
    conversation_id
    created_at
    (conversation_id, created_at)
  }
}

Table message_reads {
  message_id int [not null]
  user_id int [not null]
  read_at datetime [not null]

  indexes {
    (message_id, user_id) [pk]
  }
}

Table message_reactions {
  id int [pk, increment]
  message_id int [not null]
  user_id int [not null]
  emoji varchar [not null]
  created_at datetime [not null]

  indexes {
    (message_id, user_id) [unique]
  }
}

Table message_media {
  id int [pk, increment]
  message_id int [not null]
  media_url varchar [not null]
  media_type varchar [not null]
  file_name varchar
  file_size int
  duration int
  thumbnail_url varchar
  created_at datetime [not null]
}

Table chatbot_sessions {
  id int [pk, increment]
  user_id int
  coze_conversation_id varchar
  title varchar
  created_at datetime [not null]
  updated_at datetime [not null]

  indexes {
    user_id
    coze_conversation_id
  }
}

Table chatbot_messages {
  id int [pk, increment]
  session_id int [not null]
  sender varchar [not null]
  content varchar [not null]
  created_at datetime [not null]

  indexes {
    session_id
  }
}

Table api_logs {
  id int [pk, increment]
  method varchar(10) [not null]
  path varchar(2048) [not null]
  status_code int [not null]
  user_id int
  ip varchar(64)
  user_agent varchar(512)
  duration_ms int [not null]
  created_at datetime [not null]

  indexes {
    created_at
    user_id
    status_code
    (method, path)
  }
}

Table return_requests {
  id int [pk, increment]
  order_id int [not null]
  user_id int [not null]
  reason varchar [not null]
  status return_request_status [not null, default: "pending"]
  admin_note varchar
  refund_amount decimal
  created_at datetime [not null]
  updated_at datetime [not null]

  indexes {
    order_id
    user_id
    status
  }
}

// POSTS / SOCIAL CONTENT

Table posts {
  id int [pk, increment]
  user_id int [not null]
  shop_id int
  post_type varchar [not null, default: "post"]
  title varchar
  content_md varchar [not null]
  moderation_status moderation_status [not null, default: "approved"]
  visibility varchar [not null, default: "public"]
  view_count int [not null, default: 0]
  like_count int [not null, default: 0]
  created_at datetime [not null]
  updated_at datetime [not null]
  is_story boolean [not null, default: false]
  story_type varchar
  media_url varchar
  thumbnail_url varchar
  duration int
  caption varchar
  background_color varchar
  text_color varchar
  text_position varchar
  expires_at datetime

  indexes {
    user_id
    shop_id
  }
}

Table post_media {
  id int [pk, increment]
  post_id int [not null]
  media_url varchar [not null]
  media_type varchar [not null, default: "image"]
  sort_order int [not null, default: 0]
  created_at datetime [not null]

  indexes {
    post_id
  }
}

Table post_products {
  post_id int [not null]
  product_id int [not null]

  indexes {
    (post_id, product_id) [pk]
  }
}

Table tags {
  id int [pk, increment]
  name varchar [not null]
  slug varchar [unique, not null]
}

Table post_tags {
  post_id int [not null]
  tag_id int [not null]

  indexes {
    (post_id, tag_id) [pk]
  }
}

// REFERENCES

Ref: users.role_id > role.id

Ref: auth_identities.user_id > users.id [delete: cascade]
Ref: device_otps.user_id > users.id [delete: cascade]
Ref: refresh_tokens.user_id > users.id [delete: cascade]
Ref: oauth_login_codes.user_id > users.id [delete: cascade]
Ref: addresses.user_id > users.id

Ref: rolepermission.role_id > role.id
Ref: rolepermission.permission_id > permission.id
Ref: userpermission.user_id > users.id
Ref: userpermission.permission_id > permission.id

Ref: shops.owner_id > users.id
Ref: shop_addresses.shop_id > shops.id
Ref: shop_staffs.shop_id > shops.id
Ref: shop_staffs.user_id > users.id

Ref: categories.parent_id > categories.id
Ref: products.shop_id > shops.id
Ref: products.brand_id > brands.id
Ref: product_categories.product_id > products.id
Ref: product_categories.category_id > categories.id
Ref: product_media.product_id > products.id
Ref: product_variants.product_id > products.id

Ref: carts.user_id > users.id
Ref: cart_items.cart_id > carts.id
Ref: cart_items.product_id > products.id
Ref: cart_items.variant_id > product_variants.id

Ref: orders.user_id > users.id
Ref: orders.shop_id > shops.id
Ref: orders.shipping_address_id > addresses.id
Ref: orders.pickup_address_id > shop_addresses.id
Ref: order_items.order_id > orders.id
Ref: order_items.product_id > products.id
Ref: order_items.variant_id > product_variants.id
Ref: payments.order_id > orders.id
Ref: shipments.order_id > orders.id
Ref: shipment_logs.shipment_id > shipments.id

Ref: reviews.user_id > users.id
Ref: reviews.product_id > products.id
Ref: wishlists.user_id > users.id
Ref: wishlists.product_id > products.id

Ref: skin_analyses.user_id > users.id
Ref: tryon_sessions.user_id > users.id
Ref: tryon_items.session_id > tryon_sessions.id
Ref: tryon_items.product_id > products.id
Ref: tryon_items.variant_id > product_variants.id
Ref: recommendations.user_id > users.id

Ref: order_coupons.order_id > orders.id
Ref: order_coupons.coupon_id > coupons.id
Ref: order_coupons.user_voucher_id > user_vouchers.id
Ref: user_vouchers.user_id > users.id
Ref: user_vouchers.coupon_id > coupons.id
Ref: user_vouchers.order_id > orders.id
Ref: vr_model_reviews.user_id > users.id
Ref: vr_model_reviews.reward_voucher_id > user_vouchers.id
Ref: vr_review_prompt_settings.user_id > users.id [delete: cascade]

Ref: user_wallets.user_id > users.id
Ref: user_wallet_transactions.wallet_id > user_wallets.id
Ref: user_wallet_transactions.order_id > orders.id
Ref: wallet_topup_requests.wallet_id > user_wallets.id

Ref: seller_wallets.shop_id > shops.id
Ref: wallet_transactions.wallet_id > seller_wallets.id
Ref: wallet_transactions.order_id > orders.id
Ref: platform_revenue.order_id > orders.id
Ref: platform_revenue.shop_id > shops.id
Ref: payout_requests.shop_id > shops.id
Ref: payout_requests.wallet_id > seller_wallets.id
Ref: payout_requests.bank_account_id > shop_bank_accounts.id
Ref: shop_bank_accounts.shop_id > shops.id

Ref: moderation_logs.moderator_id > users.id
Ref: notifications.user_id > users.id
Ref: audit_logs.actor_id > users.id

Ref: conversation_participants.conversation_id > conversations.id [delete: cascade]
Ref: conversation_participants.user_id > users.id [delete: cascade]
Ref: conversation_participants.shop_id > shops.id [delete: cascade]
Ref: messages.conversation_id > conversations.id [delete: cascade]
Ref: messages.sender_id > users.id [delete: set null]
Ref: messages.sender_shop_id > shops.id [delete: set null]
Ref: messages.reply_to_id > messages.id
Ref: message_reads.message_id > messages.id
Ref: message_reads.user_id > users.id
Ref: message_reactions.message_id > messages.id [delete: cascade]
Ref: message_reactions.user_id > users.id
Ref: message_media.message_id > messages.id [delete: cascade]
Ref: chatbot_sessions.user_id > users.id [delete: set null]
Ref: chatbot_messages.session_id > chatbot_sessions.id [delete: cascade]

Ref: api_logs.user_id > users.id

Ref: return_requests.order_id > orders.id
Ref: return_requests.user_id > users.id

Ref: posts.user_id > users.id
Ref: posts.shop_id > shops.id
Ref: post_media.post_id > posts.id [delete: cascade]
Ref: post_products.post_id > posts.id [delete: cascade]
Ref: post_products.product_id > products.id [delete: cascade]
Ref: post_tags.post_id > posts.id [delete: cascade]
Ref: post_tags.tag_id > tags.id [delete: cascade]
