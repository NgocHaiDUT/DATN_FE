# Docker Compose build/runtime values. Copy this to .env on the EC2 server
# next to docker-compose.prod.yml, then adjust domains/IPs.

# Next.js server-side rewrite target. Inside Compose, backend is reachable by service name.
BACKEND_URL=http://backend:3000

# Browser-facing API values for the user frontend.
# Keep /api-proxy if you want Next.js to proxy API requests to BACKEND_URL.
NEXT_PUBLIC_API_URL=/api-proxy
NEXT_PUBLIC_API_BASE_URL=/api-proxy

# Browser-facing Socket.IO URL. Use your public API origin in production if chat uses sockets.
NEXT_PUBLIC_SOCKET_URL=https://api.your-domain.com

# Browser-facing API value for the admin Vite app.
VITE_API_BASE_URL=https://api.your-domain.com
